# ─────────────────────────────────────────────────────────────────────────────
# Ruby Ankur Wellness — environment variables
# Copy this file to `.env.local` and fill in values from your Supabase project:
#   Supabase Dashboard → Project Settings → API
# `.env.local` is git-ignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# Public — safe to expose to the browser. Found under "Project URL" and the
# public "anon" / "publishable" API key.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER expose to the browser or commit. Bypasses Row Level
# Security; used for migrations, seed scripts, and trusted server jobs only.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Feature flag: show the Phone OTP login option. Leave unset/false until an SMS
# provider is configured in Supabase (Authentication -> Providers -> Phone).
# When false, login shows Email + Password only.
NEXT_PUBLIC_ENABLE_PHONE_OTP=false
