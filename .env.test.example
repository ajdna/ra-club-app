# Copy to `.env.test` (git-ignored) to enable the logged-in browser tests.
#
# Use a DEDICATED TEST account — never your real admin login — so the tests
# never read or change real club data. Create one in Supabase:
#   Dashboard -> Authentication -> Users -> Add user (email + password),
#   then approve it in the app if needed.

# Optional: point the tests at a deployed site instead of a local server.
# BASE_URL=https://ra-club-app-git-main-ra-club-s-projects.vercel.app

TEST_EMAIL=
TEST_PASSWORD=
