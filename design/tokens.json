{
  "$meta": {
    "name": "Ruby Ankur Wellness — Design Tokens",
    "version": "1.0.0",
    "note": "Names map 1:1 to src/app/globals.css (brief Section 4) + a few documented additions. Only --emerald changed value: #1a5e32 -> #15663b (more vibrant, holds WCAG AA). Every other value matches the brief."
  },
  "color": {
    "light": {
      "cream": "#f5f0e6",
      "cream-2": "#ede5d4",
      "card": "#fffefb",
      "emerald": "#15663b",
      "emerald-2": "#1c7a47",
      "emerald-soft": "rgba(21,102,59,0.10)",
      "terra": "#e07228",
      "terra-d": "#b55d18",
      "terra-soft": "rgba(224,114,40,0.12)",
      "sage": "#6b8f5e",
      "sage-d": "#4a6642",
      "ink": "#1c1409",
      "ink-2": "#6b6253",
      "ink-3": "#9a9180",
      "gold": "#c89a3c",
      "good": "#2e7d4f",
      "warn": "#c8902b",
      "bad": "#b04830",
      "line": "#e0d8c6"
    },
    "dark": {
      "cream": "#14110b",
      "cream-2": "#1c1810",
      "card": "#211c13",
      "emerald": "#3fae78",
      "emerald-2": "#4cbf86",
      "emerald-soft": "rgba(63,174,120,0.16)",
      "terra": "#f08a44",
      "terra-d": "#d97328",
      "terra-soft": "rgba(240,138,68,0.16)",
      "sage": "#8fae82",
      "sage-d": "#6b8f5e",
      "ink": "#f3ecdc",
      "ink-2": "#b9b09c",
      "ink-3": "#8a8170",
      "gold": "#d9b057",
      "good": "#4fb87a",
      "warn": "#e0ad4a",
      "bad": "#d56a52",
      "line": "#322b1d"
    }
  },
  "font": {
    "sans": "Manrope, ui-sans-serif, system-ui, sans-serif",
    "display": "Fraunces, ui-serif, Georgia, serif",
    "weights": { "regular": 400, "medium": 500, "semibold": 600 }
  },
  "fontSize": {
    "caption": { "px": 12, "family": "sans", "weight": 600 },
    "label":   { "px": 13, "family": "sans", "weight": 600 },
    "body":    { "px": 15, "family": "sans", "weight": 500 },
    "title":   { "px": 16, "family": "sans", "weight": 600 },
    "h3":      { "px": 18, "family": "display", "weight": 500 },
    "h2":      { "px": 22, "family": "display", "weight": 500 },
    "h1":      { "px": 28, "family": "display", "weight": 500 },
    "metric":  { "px": 56, "family": "display", "weight": 500 }
  },
  "spacing": { "base": 8, "scale": [4, 8, 12, 16, 20, 24, 32] },
  "radius": {
    "sm": 10,
    "md": 14,
    "lg": 16,
    "xl": 18,
    "full": 9999
  },
  "elevation": {
    "e0": "1px solid var(--line)",
    "e1": { "light": "0 1px 3px rgba(28,20,9,0.08)", "dark": "0 1px 3px rgba(0,0,0,0.4)" },
    "e2": { "light": "0 14px 30px rgba(21,102,59,0.16)", "dark": "0 14px 30px rgba(0,0,0,0.45)" }
  },
  "touchTarget": { "min": 44 }
}
